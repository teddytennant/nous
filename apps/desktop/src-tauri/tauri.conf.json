{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/refs/heads/main/nicegui/static/tauri.conf.json",
  "productName": "Nous",
  "version": "0.1.0",
  "identifier": "com.nous.desktop",
  "build": {
    "beforeBuildCommand": "cd ../web && npm run build",
    "beforeDevCommand": "cd ../web && npm run dev",
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:3000"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Nous",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Nous — Sovereign Protocol"
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8080 https://api.github.com; style-src 'self' 'unsafe-inline'; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob:; script-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "notification": {
      "sound": true
    },
    "deep-link": {
      "desktop": {
        "schemes": ["nous"]
      }
    }
  }
}
