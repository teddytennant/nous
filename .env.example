# Nous environment variables
# Copy to .env and modify as needed.

# Logging level — passed to tracing-subscriber's EnvFilter.
# Examples: info, debug, nous_api=trace, nous_net=debug
RUST_LOG=info

# API server bind address and port.
# The gRPC server runs on NOUS_API_PORT + 1 (default 8081).
# These are not yet read from env at runtime — they are compile-time defaults
# in crates/nous-api/src/config.rs. Listed here for reference.
# NOUS_API_HOST=0.0.0.0
# NOUS_API_PORT=8080

# Data directory for SQLite database, keys, and files.
# Default: ~/.nous/
# NOUS_DATA_DIR=~/.nous/

# Web app — API base URL (used by Next.js at build/runtime)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
